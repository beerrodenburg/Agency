    <script>
      // Dynamic date in BREAKING banner
      const d = new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }).toUpperCase();
      document.getElementById('breaking-date').textContent = d;

      // FAQ accordion
      document.addEventListener('DOMContentLoaded', function() {
        const buttons = document.querySelectorAll('.faq-button');
        buttons.forEach(function(button, index) {
          button.addEventListener('click', function() {
            const isOpen = button.getAttribute('data-open') === 'true';
            // Close all
            buttons.forEach(function(b, i) {
              b.setAttribute('data-open', 'false');
              b.querySelector('.chevron-down').classList.remove('hidden');
              b.querySelector('.chevron-up').classList.add('hidden');
              const ans = document.getElementById('faq-answer-' + i);
              if (ans) ans.classList.add('hidden');
            });
            // Open clicked if it was closed
            if (!isOpen) {
              button.setAttribute('data-open', 'true');
              button.querySelector('.chevron-down').classList.add('hidden');
              button.querySelector('.chevron-up').classList.remove('hidden');
              const answer = document.getElementById('faq-answer-' + index);
              if (answer) {
                answer.classList.remove('hidden');
                setTimeout(function() {
                  answer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                }, 50);
              }
            }
          });
        });
      });
